<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="fishing_robot">

  <!-- Architecture flags (overridden by the launch file). -->
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="headless" default="false"/>

  <link name="base_link">
    <inertial>
      <origin xyz="9.64494158785974E-06 -0.0124364350363364 -0.00800838743932182" rpy="0 0 0" />
      <mass value="0.10242435780476" />
      <inertia ixx="3.44658980710862E-05" ixy="1.15685827535353E-08" ixz="-4.74633377970236E-09" iyy="7.35797461812803E-05" iyz="-3.93838381066106E-07" izz="7.91602302077541E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/base_link.STL" />
      </geometry>
      <material name=""><color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/base_link_collision.STL" />
      </geometry>
    </collision>
  </link>

  <link name="Link_1">
    <inertial>
      <origin xyz="1.98732975738997E-05 -0.000248210549754878 0.025285547707494" rpy="0 0 0" />
      <mass value="0.0497087584246774" />
      <inertia ixx="1.48173848978349E-05" ixy="4.74633377970562E-09" ixz="1.15685827535328E-08" iyy="1.25308227827468E-05" iyz="3.93501789908991E-07" izz="9.69942781916457E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/Link_1.STL" />
      </geometry>
      <material name=""><color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/Link_1_collision.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="Joint_1" type="revolute">
    <origin xyz="0 0 0.02335" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Link_1" />
    <axis xyz="0 0 1" />
    <limit lower="-3.1416" upper="3.1416" effort="2.5" velocity="5.76" />
  </joint>

  <link name="Link_2">
    <inertial>
      <origin xyz="-0.000376762904282731 0.0228500014053185 0.0758975605697149" rpy="0 0 0" />
      <mass value="0.0374844556058819" />
      <inertia ixx="9.81277949436277E-05" ixy="4.17865645290201E-13" ixz="8.66764648076052E-08" iyy="9.58497532082512E-05" iyz="1.55605785755593E-12" izz="4.42186013584717E-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/Link_2.STL" />
      </geometry>
      <material name=""><color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://description/meshes/Link_2_collision.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="Joint_2" type="revolute">
    <origin xyz="0 -0.02335 0.03875" rpy="0 0 0" />
    <parent link="Link_1" />
    <child link="Link_2" />
    <axis xyz="0 1 0" />
    <limit lower="-3.1416" upper="3.1416" effort="2.5" velocity="5.76" />
  </joint>

  <!-- Massless frame at the rod tip where the line attaches and the load cell
       measures tension. Matches the MuJoCo 'rod_tip_site' and sensor frame_id. -->
  <link name="rod_tip_link" />
  <joint name="rod_tip_joint" type="fixed">
    <origin xyz="0 0.024 0.185" rpy="0 0 0" />
    <parent link="Link_2" />
    <child link="rod_tip_link" />
  </joint>

  <!-- Simulation-only: the virtual fish. ros2_control requires every commanded
       joint to exist in the URDF, so we declare the fish's slide joint here (it
       also exists in the MJCF, where it is physically simulated). Not part of the
       real arm, hence gated on use_sim. -->
  <xacro:if value="$(arg use_sim)">
    <link name="fish_link" />
    <joint name="fish_swim" type="prismatic">
      <origin xyz="0 -0.4 0.2" rpy="0 0 0" />
      <parent link="base_link" />
      <child link="fish_link" />
      <axis xyz="0 -1 0" />
      <limit lower="-1.0" upper="1.0" effort="10.0" velocity="10.0" />
    </joint>
  </xacro:if>

  <ros2_control name="FishingRobotHardware" type="system">
    <hardware>
        <xacro:if value="$(arg use_sim)">
            <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
            <!-- The MJCF scene the plugin loads, steps and renders. -->
            <param name="mujoco_model">$(find description)/urdf/fishing-robot_sim.xml</param>
            <!-- Apply this MJCF keyframe as the initial state on boot (no manual
                 keyframe selection needed in the viewer). -->
            <param name="initial_keyframe">starting_pose</param>
            <!-- Run with (false) or without (true) the MuJoCo GUI window. -->
            <param name="headless">$(arg headless)</param>
        </xacro:if>
        <xacro:unless value="$(arg use_sim)">
            <plugin>dynamixel_hardware/DynamixelHardware</plugin>
            <param name="usb_port">/dev/ttyUSB0</param>
            <param name="baud_rate">57600</param>
            <param name="use_dummy">false</param> 
        </xacro:unless>
    </hardware>

    <joint name="Joint_1">
        <param name="id">1</param>
        <command_interface name="position">
            <param name="min">-3.1416</param>
            <param name="max">3.1416</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
    </joint>

    <joint name="Joint_2">
        <param name="id">2</param>
        <command_interface name="position">
            <param name="min">-3.1416</param>
            <param name="max">3.1416</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
    </joint>

    <!-- Simulation-only interfaces: the virtual fish and the line load cell exist
         in the MuJoCo scene, not on the physical arm. -->
    <xacro:if value="$(arg use_sim)">
        <!-- The fish's pull: 1-DOF slide joint driven by an effort command
             (forward_command_controller -> MuJoCo 'fish_force' motor). -->
        <joint name="fish_swim">
            <command_interface name="effort"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <!-- Line tension load cell: MuJoCo force+torque at the rod tip mapped to a
             single FTS, published by force_torque_sensor_broadcaster. The plugin
             reads MJCF sensors 'tension_sensor_force' and 'tension_sensor_torque'. -->
        <sensor name="tension_sensor">
            <param name="mujoco_type">fts</param>
            <param name="mujoco_sensor_name">tension_sensor</param>
            <state_interface name="force.x"/>
            <state_interface name="force.y"/>
            <state_interface name="force.z"/>
            <state_interface name="torque.x"/>
            <state_interface name="torque.y"/>
            <state_interface name="torque.z"/>
        </sensor>
    </xacro:if>
  </ros2_control>

</robot>