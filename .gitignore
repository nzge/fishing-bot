# --- ROS 2 / Colcon Build Patterns ---
# This matches build, install, and log folders anywhere inside the 'software' directory
software/**/build/
software/**/install/
software/**/log/
software/**/.colcon/

# --- General Python/System Patterns ---
# --- Python Artifacts ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.env/
.pytest_cache/
.tox/

# --- CAD / Simulation Specific (Recommended) ---
# Ignore temporary SolidWorks/CAD files
**/$*.*
**/~*.*
**/*.bak
**/*.tmp

# Ignore virtual environments
.venv/

# --- IDE / Editor Files ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Simulation / Data ---
# ignore local log files or temporary csvs
*.csv
*.log
*.bak

# --- MuJoCo Simulation Artifacts ---
# Ignore all text logs and binary model files
*.TXT
*.txt
*.mjb
*.png
MUJOCO_LOG.TXT

# Ignore direnv environment cache
.direnv/

